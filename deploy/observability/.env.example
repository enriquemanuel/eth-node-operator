# Copy to .env and fill in values before deploying

# ── Node identity ────────────────────────────────────────────────────
NODE_NAME=bare-metal-01
CLUSTER_NAME=mainnet-validators
ENVIRONMENT=production

# ── Mimir remote write ───────────────────────────────────────────────
MIMIR_REMOTE_WRITE_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
MIMIR_USERNAME=123456
MIMIR_PASSWORD=glc_xxxxxxxx

# ── Loki ─────────────────────────────────────────────────────────────
LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
LOKI_USERNAME=123456
LOKI_PASSWORD=glc_xxxxxxxx

# ── Route 53 DNS (for A-record registration) ─────────────────────────
# Agent uses the aws CLI to upsert: {nodeName}-{elClient}.{zone} → public IP
# IAM policy needed: route53:ChangeResourceRecordSets on the hosted zone
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# ── Network probe (blackbox_exporter) ────────────────────────────────
DEFAULT_GATEWAY=10.0.0.1

# ── Client endpoints ─────────────────────────────────────────────────
EL_RPC_URL=http://localhost:8545
CL_REST_URL=http://localhost:5052
