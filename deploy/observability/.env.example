# Copy to .env and fill in values before deploying

# ── Node identity ───────────────────────────────────────────────────
NODE_NAME=bare-metal-01
CLUSTER_NAME=mainnet-validators
ENVIRONMENT=production

# ── Mimir remote write ──────────────────────────────────────────────
MIMIR_REMOTE_WRITE_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
MIMIR_USERNAME=123456
MIMIR_PASSWORD=glc_xxxxxxxx

# ── Loki ────────────────────────────────────────────────────────────
LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
LOKI_USERNAME=123456
LOKI_PASSWORD=glc_xxxxxxxx

# ── Traefik TLS (Cloudflare DNS-01) ─────────────────────────────────
ACME_EMAIL=ops@example.com
CF_DNS_API_TOKEN=your_cloudflare_api_token
TRAEFIK_WEB_PORT=443
TRAEFIK_WEB_HTTP_PORT=80
TRAEFIK_TAG=v3.3

# ── Traefik domains ─────────────────────────────────────────────────
# ethagent management API (ethctl uses this)
DOMAIN=agent.bare-metal-01.validators.example.com

# Beacon node HTTPS endpoint — Lighthouse VC connects here
# CNAME this to the node's IP in Cloudflare DNS
BEACON_DOMAIN=beacon.bare-metal-01.validators.example.com

# ── VC gateway access control ────────────────────────────────────────
# EKS NAT gateway egress IPs — who is allowed to reach :443 (beacon route)
# Set in both UFW (via spec.network.vcGateways) and Traefik IPAllowList.
# Find your EKS NAT gateway IPs: aws ec2 describe-nat-gateways
VC_GATEWAY_CIDR_1=10.0.1.0/24
VC_GATEWAY_CIDR_2=10.0.2.0/24
# Add VC_GATEWAY_CIDR_3, _4 etc in beacon.yml if you have more

# ── Network probe (blackbox_exporter) ───────────────────────────────
DEFAULT_GATEWAY=10.0.0.1

# ── Client endpoints ─────────────────────────────────────────────────
EL_RPC_URL=http://localhost:8545
CL_REST_URL=http://localhost:5052
