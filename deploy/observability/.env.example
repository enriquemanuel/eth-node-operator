# Copy to .env and fill in values before deploying

# ── Node identity ───────────────────────────────────────────
NODE_NAME=bare-metal-01
CLUSTER_NAME=mainnet-validators
ENVIRONMENT=production

# ── Mimir remote write ──────────────────────────────────────
MIMIR_REMOTE_WRITE_URL=https://prometheus-prod-XX-prod-XX.grafana.net/api/prom/push
MIMIR_USERNAME=123456
MIMIR_PASSWORD=glc_xxxxxxxx

# ── Loki ───────────────────────────────────────────────────
LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
LOKI_USERNAME=123456
LOKI_PASSWORD=glc_xxxxxxxx

# ── Traefik TLS (Cloudflare DNS-01) ────────────────────────
DOMAIN=node01.example.com
ACME_EMAIL=ops@example.com
CF_DNS_API_TOKEN=your_cloudflare_api_token
TRAEFIK_WEB_PORT=443
TRAEFIK_WEB_HTTP_PORT=80

# ── Network probes (blackbox_exporter) ─────────────────────
# Your upstream router / default gateway IP
DEFAULT_GATEWAY=10.0.0.1

# ── Client endpoints ────────────────────────────────────────
EL_RPC_URL=http://localhost:8545
CL_REST_URL=http://localhost:5052

# ── Traefik image ───────────────────────────────────────────
TRAEFIK_TAG=v3.3
